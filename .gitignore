# ── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/

# ── Node / frontend build ────────────────────────────────────────────────────
node_modules/
dashboard/frontend/dist/
dashboard/frontend/dist-electron/

# ── Electron build output ────────────────────────────────────────────────────
release/
out/

# ── iOS (Capacitor leftover) ────────────────────────────────────────────────
ios/

# ── Native Android build artifacts (source lives in android/) ───────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/*.iml
android/app/*.iml

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
